# ProjectLens AI — Production Environment
# Copy to .env.production and fill in real values

## Application
PROJECT_NAME=ProjectLens AI
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

## Database (PostgreSQL) — use SSL connection string
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/projectlens?sslmode=require

## Cache (Redis)
REDIS_URL=redis://redis:6379/0

## JWT Authentication
# Generate: openssl rand -hex 64
SECRET_KEY=replace-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

## Storage
STORAGE_PROVIDER=supabase

## Supabase (required if STORAGE_PROVIDER=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=reports

## File Upload
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=.pdf,.docx

## CORS — set to your frontend domain(s)
CORS_ORIGINS=["https://app.yourdomain.com"]
