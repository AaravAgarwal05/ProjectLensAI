# ProjectLens AI — Environment Variables Template
# Copy to .env.local for development: cp .env.example .env.local

## Application
PROJECT_NAME=ProjectLens AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

## Database (PostgreSQL)
# Docker:  postgresql+asyncpg://postgres:postgres@postgres:5432/projectlens
# Local:   postgresql+asyncpg://postgres:postgres@localhost:5432/projectlens
# Produc:  postgresql+asyncpg://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/projectlens

## Cache (Redis)
# Docker:  redis://redis:6379/0
# Local:   redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

## JWT Authentication
SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

## Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./data/storage

## Supabase (optional — required if STORAGE_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=reports

## File Upload
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=.pdf,.docx

## CORS
CORS_ORIGINS=["http://localhost:3000"]
